# KINEMATIC BACKEND — ENVIRONMENT VARIABLES

# Supabase Configuration — DEFAULT project
# You can find these in Project Settings > API. This is the single, original
# project (the Tata tenant + every mobile app route here by default).
SUPABASE_URL=your_project_url
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Token verification for the default project (optional but recommended — avoids
# a gotrue round-trip per cold request). Set either the JWKS URL (modern signing
# keys) or the legacy JWT secret.
# SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_SECRET=your_legacy_jwt_secret
# Optional storage + edge config for the default project.
# SUPABASE_STORAGE_BUCKET=distribution
# SUPABASE_EDGE_FUNCTIONS_URL=https://<project-ref>.supabase.co/functions/v1
# SUPABASE_EDGE_SECRET=your_edge_shared_secret

# ── Multi-project: KINEMATIC project ─────────────────────────────────
# Per-customer Supabase project for hard data isolation. Requests are routed
# here ONLY when they carry `X-Kinematic-Project: kinematic` (the web dashboard
# stamps this after resolving the user's email via /auth/project-for-email).
# If these three are unset, the backend runs single-project and behaves exactly
# as before — so this whole block is safe to leave blank until cutover.
KINEMATIC_SUPABASE_URL=
KINEMATIC_SUPABASE_ANON_KEY=
KINEMATIC_SUPABASE_SERVICE_ROLE_KEY=
# KINEMATIC_SUPABASE_JWKS_URL=https://<kinematic-ref>.supabase.co/auth/v1/.well-known/jwks.json
# KINEMATIC_SUPABASE_JWT_SECRET=
# KINEMATIC_SUPABASE_STORAGE_BUCKET=distribution
# KINEMATIC_SUPABASE_EDGE_FUNCTIONS_URL=https://<kinematic-ref>.supabase.co/functions/v1
# KINEMATIC_SUPABASE_EDGE_SECRET=

# email → project routing directory (used by /auth/project-for-email).
# Exact-email entries win over domain entries. Prefer exact-email mapping for
# shared domains (e.g. @kinematicapp.com staff who belong to the default tenant
# must NOT be domain-routed). Anything unmatched → default project.
#   PROJECT_EMAIL_DIRECTORY={"s@kinematicapp.com":"kinematic"}
#   PROJECT_DOMAIN_DIRECTORY={"some-kinematic-domain.com":"kinematic"}
PROJECT_EMAIL_DIRECTORY=
PROJECT_DOMAIN_DIRECTORY=

# Database Connection (Direct)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (if not using Supabase Auth internally)
JWT_SECRET=your_jwt_secret

# ── Anthropic / Claude AI ────────────────────────────────────
# Required for CRM AI features: lead scoring, draft replies, KINI chat.
# Get your key at: https://console.anthropic.com/settings/keys
# Add this to your .env file (NOT .env.example) and restart the server.
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Optional: org-managed key rotation (advanced, leave blank if unsure)
# ANTHROPIC_ORG_KEY_ID=your_org_key_id
# ANTHROPIC_ADMIN_KEY=your_admin_key

# ── Web Push (VAPID) ─────────────────────────────────────────
# Used by /api/v1/messaging/push/* to fan out browser notifications for
# DMs, team chat messages, and @mentions. If both keys are unset the
# backend silently skips push delivery (in-app bell + inbox unread badges
# still work). Generate a fresh keypair with:
#   npx -p web-push web-push generate-vapid-keys --json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@kinematicapp.com

# ── Outbound email (CRM email alerts + verification) ─────────
# Pick a provider; the rest of the integration (templates, alerts,
# scheduler) is provider-agnostic via src/services/crm/providers/.
#
#   EMAIL_PROVIDER=resend          → uses RESEND_API_KEY
#   EMAIL_PROVIDER=stub (default)  → no-ops the send, logs to DB only
#
# DASHBOARD_URL is embedded into the sender-verification link emailed
# to a tenant's address. CRM_FROM_EMAIL is the fallback sender when no
# verified per-tenant address has been picked (e.g. system notifications).
EMAIL_PROVIDER=stub
RESEND_API_KEY=
CRM_FROM_EMAIL=noreply@mail.kinematicapp.com
CRM_TRACKING_DOMAIN=mail.kinematicapp.com
DASHBOARD_URL=https://dashboard.kinematicapp.com
